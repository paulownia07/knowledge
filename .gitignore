# Not sure what a .gitignore is?
# See: https://git-scm.com/docs/gitignore

# These are directly copied from Jekyll's first-party docs on `.gitignore` files:
# https://jekyllrb.com/tutorials/using-jekyll-with-bundler/#commit-to-source-control

# Ignore the default location of the built site, and caches and metadata generated by Jekyll
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata

# Ignore folders generated by Bundler
.bundle/
vendor/

# Ignore pending folders
docs/apache_spark/*
docs/databricks/*
docs/django/*
docs/java/*
docs/javascript/*
docs/kubernetes/*
docs/linux/linux_a*
docs/linux/linux_boot.md
docs/linux/linux_d*
docs/linux/linux_f*
docs/linux/linux_g*
docs/linux/linux_j*
docs/linux/linux_l*
docs/linux/linux_n*
docs/linux/linux_o*
docs/linux/linux_p*
docs/linux/linux_r*
docs/linux/linux_s*
docs/linux/linux_t*
docs/linux/linux_v*
docs/python/WIP*
docs/snowflake/*
docs/vscode/*